{
    "name": "enadstack/laravel-country-data",
    "description": "Laravel package for country information (config-based, reusable, and localized)",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Enad Abu Zaid",
            "email": "enad@enadstack.com",
            "homepage": "https://enadstack.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Enadstack\\CountryData\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Enadstack\\CountryData\\CountryDataServiceProvider"
            ],
            "aliases": {
                "CountryData": "Enadstack\\CountryData\\Facades\\CountryData"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
